  journal     = {Physical Review B},
  year        = {2025},
  note        = {Under review},
  abstract    = {Amorphous Ga$_2$O$_3$ is a low-temperature-synthesizable phase used in photodetectors and resistive switching memories. We investigate self-trapped hole formation across crystalline and amorphous phases and show that holes localise on precursor O sites to form polarons, whereas electrons remain delocalised.}
}

